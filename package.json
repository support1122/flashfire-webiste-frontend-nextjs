{
  "name": "flashfire-nextjs-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext ts,tsx --max-warnings=0",
    "type-check": "tsc --noEmit",
    "pages:build": "npx @cloudflare/next-on-pages",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@maxmind/geoip2-node": "^6.3.4",
    "bcrypt": "^6.0.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.553.0",
    "next": "^16.0.7",
    "pdf-parse": "^1.1.1",
    "posthog-js": "^1.290.0",
    "react": "19.2.0",
    "react-calendly": "^4.4.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.5.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "critters": "^0.0.25",
    "eslint": "^9",
    "eslint-config-next": "^16.0.7",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "3.8.0",
    "tailwindcss": "^4",
    "terser": "^5.36.0",
    "typescript": "^5"
  }
}
